rule fastaguard:
    input:
        fasta="sample.fa"
    output:
        html="fastaguard_report.html",
        json="fastaguard.json",
        tsv="fastaguard.tsv",
        multiqc="fastaguard_mqc.json"
    shell:
        """
        # Gate failures intentionally exit 2 after writing reports.
        fastaguard {input.fasta} \
          --profile assembly \
          --gate pipeline \
          --out {output.html} \
          --json {output.json} \
          --tsv {output.tsv} \
          --multiqc {output.multiqc}
        """
