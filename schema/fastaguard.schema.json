{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastaguard.dev/schema/fastaguard.schema.json",
  "title": "FastaguardReport",
  "description": "Machine-readable FastaGuard FASTA preflight QC report.",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "input",
    "verdict",
    "machine_summary",
    "scope",
    "provenance",
    "summary",
    "plots",
    "findings",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0",
      "description": "Version of the FastaGuard report schema."
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "FastaGuard"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "input": {
      "type": "object",
      "required": ["path", "profile", "compressed"],
      "properties": {
        "path": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "compressed": {
          "type": "boolean"
        }
      }
    },
    "verdict": {
      "type": "object",
      "required": ["status", "reasons"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "WARN", "FAIL"]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "machine_summary": {
      "type": "object",
      "required": [
        "verdict",
        "safe_for_downstream",
        "top_findings",
        "recommended_next_tools",
        "routing_hints"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASS", "WARN", "FAIL"]
        },
        "safe_for_downstream": {
          "type": "boolean"
        },
        "top_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_next_tools": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recommended_tool"
          }
        },
        "routing_hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routing_hint"
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "required": ["level", "can_conclude", "cannot_conclude"],
      "properties": {
        "level": {
          "const": "fasta_preflight"
        },
        "can_conclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cannot_conclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "profile",
        "threads",
        "fail_on",
        "thresholds",
        "command",
        "started_at",
        "completed_at",
        "duration_ms",
        "input_size_bytes"
      ],
      "properties": {
        "profile": {
          "type": "string"
        },
        "threads": {
          "type": "integer",
          "minimum": 1
        },
        "fail_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "thresholds": {
          "type": "object",
          "required": [
            "high_n_sequence_fraction",
            "high_global_n_fraction",
            "min_contig_length",
            "max_gap_run",
            "gc_outlier_zscore"
          ],
          "properties": {
            "high_n_sequence_fraction": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "high_global_n_fraction": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "min_contig_length": {
              "type": "integer",
              "minimum": 0
            },
            "max_gap_run": {
              "type": "integer",
              "minimum": 0
            },
            "gc_outlier_zscore": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "command": {
          "type": "string"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "input_size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "sequence_count",
        "total_length",
        "min_length",
        "max_length",
        "mean_length",
        "median_length",
        "n50",
        "n90",
        "l50",
        "l90",
        "gc_percent",
        "at_percent",
        "n_percent",
        "ambiguity_percent",
        "duplicate_id_count",
        "duplicate_sequence_count",
        "invalid_sequence_count",
        "high_n_sequence_count",
        "tiny_contig_count",
        "max_gap_run"
      ],
      "properties": {
        "sequence_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_length": {
          "type": "integer",
          "minimum": 0
        },
        "min_length": {
          "type": "integer",
          "minimum": 0
        },
        "max_length": {
          "type": "integer",
          "minimum": 0
        },
        "mean_length": {
          "type": "number",
          "minimum": 0
        },
        "median_length": {
          "type": "number",
          "minimum": 0
        },
        "n50": {
          "type": "integer",
          "minimum": 0
        },
        "n90": {
          "type": "integer",
          "minimum": 0
        },
        "l50": {
          "type": "integer",
          "minimum": 0
        },
        "l90": {
          "type": "integer",
          "minimum": 0
        },
        "gc_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "at_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "n_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "ambiguity_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "duplicate_id_count": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_sequence_count": {
          "type": "integer",
          "minimum": 0
        },
        "invalid_sequence_count": {
          "type": "integer",
          "minimum": 0
        },
        "high_n_sequence_count": {
          "type": "integer",
          "minimum": 0
        },
        "tiny_contig_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_gap_run": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "plots": {
      "type": "object",
      "required": ["length_histogram", "gc_length_plot"],
      "properties": {
        "length_histogram": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/length_histogram_bin"
          }
        },
        "gc_length_plot": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gc_length_point"
          },
          "maxItems": 5000
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["html", "tsv", "multiqc"],
      "properties": {
        "html": {
          "type": "string"
        },
        "tsv": {
          "type": "string"
        },
        "multiqc": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "length_histogram_bin": {
      "type": "object",
      "required": ["min_length", "max_length", "sequence_count", "total_length"],
      "properties": {
        "min_length": {
          "type": "integer",
          "minimum": 0
        },
        "max_length": {
          "type": "integer",
          "minimum": 0
        },
        "sequence_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_length": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "gc_length_point": {
      "type": "object",
      "required": ["id", "length", "gc_percent", "n_percent", "flags"],
      "properties": {
        "id": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "gc_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "n_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "gc_zscore": {
          "type": "number",
          "minimum": 0
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tiny_contig",
              "high_n",
              "gc_outlier",
              "length_outlier",
              "composite_anomaly"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "category",
        "severity",
        "confidence",
        "requires_followup_tool",
        "profile",
        "affected_count",
        "affected_fraction",
        "message",
        "why_it_matters",
        "suggested_next_step",
        "evidence",
        "actions"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["validity", "structure", "composition", "duplication"]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "minor", "major", "critical"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "moderate", "low"]
        },
        "requires_followup_tool": {
          "type": "boolean"
        },
        "profile": {
          "type": "string"
        },
        "affected_count": {
          "type": "integer",
          "minimum": 0
        },
        "affected_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "message": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "suggested_next_step": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/finding_evidence"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding_action"
          }
        }
      }
    },
    "finding_evidence": {
      "type": "object",
      "required": ["total_records", "truncated", "records"],
      "properties": {
        "total_records": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_record"
          }
        }
      }
    },
    "evidence_record": {
      "type": "object",
      "required": ["id", "length", "reason"],
      "properties": {
        "id": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string"
        },
        "invalid_count": {
          "type": "integer",
          "minimum": 0
        },
        "n_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "n_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "max_gap_run": {
          "type": "integer",
          "minimum": 0
        },
        "gc_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "gc_zscore": {
          "type": "number",
          "minimum": 0
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "gc_outlier",
              "high_n",
              "length_outlier",
              "duplicate_sequence",
              "invalid_chars",
              "gap_run"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "finding_action": {
      "type": "object",
      "required": [
        "action_type",
        "target",
        "reason",
        "recommended_tool",
        "requires_external_database"
      ],
      "properties": {
        "action_type": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "recommended_tool": {
          "type": "string"
        },
        "requires_external_database": {
          "type": "boolean"
        }
      }
    },
    "recommended_tool": {
      "type": "object",
      "required": ["tool", "reason"],
      "properties": {
        "tool": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "routing_hint": {
      "type": "object",
      "required": ["condition", "suggested_route", "requires_external_database"],
      "properties": {
        "condition": {
          "type": "string"
        },
        "suggested_route": {
          "type": "string"
        },
        "requires_external_database": {
          "type": "boolean"
        }
      }
    }
  }
}
